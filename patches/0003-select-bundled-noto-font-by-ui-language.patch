diff --git a/src/celestia/qt/qtglwidget.cpp b/src/celestia/qt/qtglwidget.cpp
index a7413646..c2f8742b 100644
--- a/src/celestia/qt/qtglwidget.cpp
+++ b/src/celestia/qt/qtglwidget.cpp
@@ -18,6 +18,8 @@
 #include "qtglwidget.h"
 
 #include <cstdlib>
+#include <filesystem>
+#include <string_view>
 #include <utility>
 
 #include <config.h>
@@ -145,6 +147,69 @@ CelestiaGlWidget::initializeGL()
         exit(1);
     }
 
+    // Pick CJK / Arabic / Georgian / Latin fonts based on the current UI
+    // language. The fonts/ directory is laid out alongside the executable.
+    {
+        const char* langOrig = N_("LANGUAGE");
+        const char* lang = _(langOrig);
+        const std::string_view code = (lang == langOrig)
+                                          ? std::string_view{}
+                                          : std::string_view{lang};
+
+        std::filesystem::path regularPath = "fonts/NotoSans-Regular.ttf";
+        std::filesystem::path boldPath    = "fonts/NotoSans-Bold.ttf";
+        int regularIndex = 0;
+        int boldIndex    = 0;
+
+        if (code == "ja")
+        {
+            regularPath = "fonts/NotoSansCJK-Regular.ttc";
+            boldPath    = "fonts/NotoSansCJK-Bold.ttc";
+            regularIndex = 0;
+            boldIndex    = 0;
+        }
+        else if (code == "ko")
+        {
+            regularPath = "fonts/NotoSansCJK-Regular.ttc";
+            boldPath    = "fonts/NotoSansCJK-Bold.ttc";
+            regularIndex = 1;
+            boldIndex    = 1;
+        }
+        else if (code == "zh_CN")
+        {
+            regularPath = "fonts/NotoSansCJK-Regular.ttc";
+            boldPath    = "fonts/NotoSansCJK-Bold.ttc";
+            regularIndex = 2;
+            boldIndex    = 2;
+        }
+        else if (code == "zh_TW")
+        {
+            regularPath = "fonts/NotoSansCJK-Regular.ttc";
+            boldPath    = "fonts/NotoSansCJK-Bold.ttc";
+            regularIndex = 3;
+            boldIndex    = 3;
+        }
+        else if (code == "ka")
+        {
+            regularPath = "fonts/NotoSansGeorgian-Regular.ttf";
+            boldPath    = "fonts/NotoSansGeorgian-Bold.ttf";
+        }
+        else if (code == "ar")
+        {
+            regularPath = "fonts/NotoSansArabic-Regular.ttf";
+            boldPath    = "fonts/NotoSansArabic-Bold.ttf";
+        }
+
+        constexpr int regularSize = 9;
+        constexpr int boldSize    = 15;
+        appCore->setHudFont(regularPath, regularIndex, regularSize);
+        appCore->setHudTitleFont(boldPath, boldIndex, boldSize);
+        appCore->setRendererFont(regularPath, regularIndex, regularSize,
+                                 Renderer::FontStyle::Normal);
+        appCore->setRendererFont(boldPath, boldIndex, boldSize,
+                                 Renderer::FontStyle::Large);
+    }
+
     appCore->tick();
 
     appRenderer->setRenderFlags(static_cast<::RenderFlags>(settings.value("RenderFlags", DEFAULT_RENDER_FLAGS).toULongLong()));
